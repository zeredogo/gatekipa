rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // KYC Document Uploads
    match /kyc/{userId}/{fileName} {
      // Allow read/write only if the authenticated user's UID matches the path
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback: block all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
